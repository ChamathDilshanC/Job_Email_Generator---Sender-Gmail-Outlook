# Google OAuth (Google Sign-In + Gmail send permission)
# Get these from https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
# Required: used server-side to exchange the auth-code sign-in flow for
# tokens (app/api/auth/google/exchange), which is what makes scheduled
# (background) email sending possible.
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Any secret string — used to derive the AES-256-GCM key that encrypts
# stored Google refresh tokens at rest. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_random_encryption_secret

# Shared secret the scheduled-email cron job must present as
# `Authorization: Bearer <CRON_SECRET>`. .github/workflows/scheduled-email-cron.yml
# is what actually calls the cron endpoint every 5 minutes (Vercel's own
# Cron only allows that frequency on the Pro plan — Hobby is capped at
# once/day, so we don't rely on it). Set the SAME value as a GitHub Actions
# repository secret named CRON_SECRET (Settings -> Secrets and variables ->
# Actions) so the workflow can authenticate.
CRON_SECRET=your_random_cron_secret

# Public base URL of this deployment (no trailing slash), e.g.
# https://your-app.vercel.app. Used by the cron job to build tracking-pixel
# links, since there's no window.location available in that context.
APP_BASE_URL=https://your-app-domain.example

# MongoDB connection string.
# Works with Azure Cosmos DB for MongoDB (RU API), MongoDB Atlas, or any
# Mongo-wire-compatible database. Get it from your Azure Cosmos DB account's
# "Connection strings" page, or your Atlas cluster's "Connect" dialog.
MONGODB_URI=your_mongodb_connection_string

# Job Portal Skills API
NEXT_PUBLIC_SKILLS_API_KEY=your_skills_api_key
NEXT_PUBLIC_SKILLS_API_BASE_URL=https://job-potal-skill-api.vercel.app
